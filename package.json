{
  "name": "new-project",
  "version": "1.0.0",
  "private": true,
  "description": "React recreation of the Cityplug Records website",
  "type": "module",
  "scripts": {
    "api": "kill-port 4000 && nodemon --watch backend --ext js,mjs --signal SIGTERM backend/server.js",
    "dev": "concurrently -k \"npm:api\" \"npm:vite\"",
    "vite": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node backend/server.js"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@vitejs/plugin-react": "^4.7.0",
    "express": "^5.2.1",
    "lucide-react": "^1.11.0",
    "mongoose": "^8.15.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "vite": "^5.4.19"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "kill-port": "^2.0.1",
    "nodemon": "^3.1.14"
  },
  "engines": {
    "node": "20.x"
  }
}
